## Стандартный .gitignore для .NET (создаётся командой dotnet new gitignore)

# Папки сборки — создаются автоматически, в репозитории не нужны
bin/
obj/

# Пользовательские настройки Rider/Visual Studio
*.user
.vs/
.idea/

## Дополнения для этого проекта

# Большие исходные файлы IMDb — сотни мегабайт, не коммитим
*.tsv.gz
title.basics.tsv
title.akas.tsv

# Файл базы данных — создаётся приложением при первом запуске
*.db

# Мусор Python
__pycache__/
*.pyc
